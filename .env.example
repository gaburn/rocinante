# Rocinante Configuration
# All values are optional — defaults are shown

# Server port
API_PORT=3001

# Path to copilot session state directory
SESSION_STATE_DIR=~/.copilot/session-state

# Path to copilot SQLite database
SQLITE_DB_PATH=~/.copilot/session-store.db

# How many bytes to read from end of events.jsonl (default: 512KB)
TAIL_BYTES=524288

# How long before a session is considered stale/completed (default: 5 min)
STALE_THRESHOLD_MS=300000

# In-memory cache lifetime (default: 10 sec)
CACHE_TTL_MS=10000

# Max events in timeline view (default: 100)
MAX_TIMELINE_EVENTS=100

# Allowed CORS origins (comma-separated, default: http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# Set to "true" to serve mock data for screenshots (no real session data needed)
DEMO_MODE=false

# Azure DevOps Integration (optional)
# When configured, workstreams can show linked work items and auto-detect PRs
# ADO auth uses Azure CLI (az login) — no PAT needed
ADO_ORG=
ADO_PROJECT=
